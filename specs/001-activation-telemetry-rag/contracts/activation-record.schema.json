{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "activation_rag.activation_record.v1",
  "type": "object",
  "required": [
    "schema_version",
    "chunk_id",
    "document_id",
    "capture_run_id",
    "provider_id",
    "model_id",
    "site_id",
    "layer_selection_policy",
    "prompt_template_id",
    "normalization_policy",
    "current_em_state",
    "neutral_baseline_state",
    "delta_vs_neutral",
    "delta_vs_current",
    "positive_mass",
    "negative_mass",
    "total_mass",
    "signed_balance",
    "sae_feature_values",
    "sae_feature_mask",
    "telemetry_valid"
  ],
  "properties": {
    "schema_version": { "const": "activation_rag.activation_record.v1" },
    "chunk_id": { "type": "string" },
    "document_id": { "type": "string" },
    "capture_run_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "model_id": { "type": "string" },
    "model_hash": { "type": ["string", "null"] },
    "tokenizer_hash": { "type": ["string", "null"] },
    "site_id": { "type": "string" },
    "hook_name": { "type": ["string", "null"] },
    "layer_index": { "type": ["integer", "null"] },
    "layer_selection_policy": { "type": "string" },
    "prompt_template_id": { "type": "string" },
    "prompt_template_hash": { "type": ["string", "null"] },
    "normalization_policy": { "type": "string" },
    "token_start": { "type": "integer", "minimum": 0 },
    "token_end": { "type": "integer", "minimum": 0 },
    "aggregation": { "type": "string" },
    "current_em_state": { "type": "object", "additionalProperties": { "type": "number" } },
    "neutral_baseline_state": { "type": "object", "additionalProperties": { "type": "number" } },
    "prior_current_state": { "type": "object", "additionalProperties": { "type": "number" } },
    "delta_vs_neutral": { "type": "object", "additionalProperties": { "type": "number" } },
    "delta_vs_current": { "type": "object", "additionalProperties": { "type": "number" } },
    "saturation": { "type": "object", "additionalProperties": { "type": "number" } },
    "residual_headroom": { "type": "object", "additionalProperties": { "type": "number" } },
    "positive_mass": { "type": "number" },
    "negative_mass": { "type": "number" },
    "total_mass": { "type": "number" },
    "signed_balance": { "type": "number" },
    "sae_feature_values": { "type": "object", "additionalProperties": { "type": "number" } },
    "sae_delta_vs_neutral": { "type": "object", "additionalProperties": { "type": "number" } },
    "sae_delta_vs_current": { "type": "object", "additionalProperties": { "type": "number" } },
    "sae_feature_mask": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "sae_novelty": { "type": ["number", "null"] },
    "sae_overlap_with_memory": { "type": ["number", "null"] },
    "telemetry_valid": { "type": "boolean" },
    "invalid_reason": { "type": ["string", "null"] },
    "provenance": { "type": "object" }
  }
}
